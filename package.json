{
  "name": "@beatly/core",
  "version": "0.6.2",
  "description": "Beatly control layer and bundled SuperCollider runtime.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://beatly.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/getbeatly/beatly"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./skill": {
      "types": "./dist/skill.d.ts",
      "import": "./dist/skill.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "beatly-event": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "supercollider",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node supercollider/server.js",
    "sc:start": "node supercollider/server.js",
    "sc:build": "sclang supercollider/build_synthdefs.scd",
    "sc:live": "sclang supercollider/play_beat.scd",
    "sc:generate": "sclang supercollider/generate.scd",
    "event": "npm run build && node dist/cli.js",
    "build:distributions": "node scripts/build-distributions.mjs",
    "build:codex-plugin": "node scripts/build-distributions.mjs --target=codex",
    "build:claude-code": "node scripts/build-distributions.mjs --target=claude-code",
    "build:pi-package": "node scripts/build-distributions.mjs --target=pi",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "beatly",
    "ai",
    "agents",
    "music",
    "supercollider",
    "pi-package"
  ],
  "pi": {
    "skills": [
      "./skills"
    ]
  },
  "dependencies": {
    "osc": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.0"
  }
}
